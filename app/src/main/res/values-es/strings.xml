    <string name="proc_engine_adapt_title">Reinicio de Adaptación del Motor</string>
    <string name="proc_engine_adapt_desc">Borra las correcciones de combustible adaptativas de la ECU. Necesario tras trabajos en el motor, cambio de inyectores o ralentí irregular.</string>
