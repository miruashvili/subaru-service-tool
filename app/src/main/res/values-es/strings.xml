    <string name="proc_throttle_fail">El motor debe estar completamente caliente (≥80°C) y el vehículo estacionado.</string>
    <string name="proc_cvt_title">Reinicio y Aprendizaje del CVT</string>
    <string name="proc_cvt_desc">Reinicia la lógica adaptativa de cambio del CVT. Necesario tras: cambio de fluido CVT, reemplazo del cuerpo de válvulas o solenoide.</string>
