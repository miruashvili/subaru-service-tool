    <string name="proc_throttle_title">Reaprendizaje del Cuerpo de Mariposa</string>
    <string name="proc_throttle_desc">Reinicia la posición base del acelerador. Necesario tras limpiar o reemplazar el cuerpo de mariposa.</string>
