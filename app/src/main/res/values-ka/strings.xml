    <!-- Maintenance tips -->
    <string name="tip_1_title">CVT-ის სითხის შეცვლა ყოველ 40,000 კმ-ზე</string>
    <string name="tip_1_body">Subaru გირჩევთ CVT-ის სითხის შეცვლას ყოველ 40,000 კმ-ზე მძიმე სამუშაო პირობებისთვის. „სიცოცხლის ვადის სითხის" მიუხედავად, გაუარესებული სითხე იწვევს სოლენოიდის ცვეთას, სრიალს და გადახურებას. გამოიყენეთ მხოლოდ Subaru-ს დამტკიცებული Lineartronic CVT სითხე (ნაწ.: SOA427V1410).</string>
    <string name="tip_2_title">TPMS-ის შემოწმება და გადაყენება საბურავის შეცვლის შემდეგ</string>
    <string name="tip_2_body">საბურავების როტაციის ან შეცვლის შემდეგ, ხელახლა დააკალიბრეთ TPMS სისტემა: გააჩერეთ მანქანა, ჩართეთ ძრავა, შემდეგ დაიჭირეთ TPMS ღილაკი საჭის ქვეშ, სანამ შუქი ორჯერ ციმციმებს. 10 წუთი 50 კმ/სთ-ზე მეტ სიჩქარეზე გაიარეთ კალიბრაციის დასასრულებლად.</string>
    <string name="tip_3_title">EyeSight კამერის მინის გაწმენდა</string>
    <string name="tip_3_body">EyeSight სტერეო კამერები მდებარეობს უკანა სარკის უკან. შეინარჩუნეთ სამ­კუ­თხა­ვი სუფ­თა — გამოიყენეთ მიკროფიბრის ქსოვილი და მინის საწმენდი, არასოდეს ამიაკის შემცველი პროდუქტები. დაბინძურება იწვევს ყალბ შეტყობინებებს და გამორთავს სისტემას.</string>
    <string name="tip_4_title">AWD სისტემა: საბურავის გარშემოწერილობის შესაბამისობის შემოწმება</string>
    <string name="tip_4_body">Subaru-ს სიმეტრიული AWD მგრძნობიარეა საბურავის ზომების შეუსაბამობის მიმართ. ყველა ოთხი საბურავი ერთმანეთს უნდა ემთხვეოდეს გარშემოწერილობის 1.6 მმ-ის ფარგლებში. მხოლოდ ერთი ან ორი საბურავის შეცვლამ შეიძლება დააზიანოს AWD ცენტრალური გადამბმელი, რაც გარანტიით არ ფარდება.</string>
    <string name="tip_5_title">სანთლები: გამოიყენეთ ირიდიუმი, არა სპილენძი</string>
    <string name="tip_5_body">Subaru FA/FB ძრავებს სჭირდება ირიდიუმის სანთლები. სპილენძის სანთლებმა შეიძლება გამოიწვიოს ანთების გამოტოვება და ECU-ს ხელახალი სწავლების პრობლემები. OEM სპეციფ.: NGK ILKAR7L11 (FA20/FB20) ან DILFR6J11 (FA24). შეცვალეთ ყოველ 60,000 კმ-ზე ან ადრე, თუ ნეიტრალური სვლა უხეში გახდება.</string>
    <string name="tip_6_title">გამაგრილებელი: გამოიყენეთ Subaru Super Coolant (ლურჯი)</string>
    <string name="tip_6_body">Subaru-ს სჭირდება საკუთარი Super Coolant (ლურჯი). სტანდარტული მწვანე ანტიფრიზი თავსებადი არ არის და დროთა განმავლობაში შეიძლება დააზიანოს ალუმინის ძრავის კომპონენტები. შეცვლის ინტერვალი: 135,000 კმ ან 11 წელი, რომელიც ადრე დადგება. ნაწ.: SOA868V9210.</string>
    <string name="tip_7_title">გაზის ხრახნის გაწმენდა ყოველ 60,000 კმ-ზე</string>
    <string name="tip_7_body">ნახშირბადის დაგროვება გაზის ფირფიტაზე იწვევს ნეიტრალური სვლის დარღვევას და გაზის გამოხმაურების პრობლემებს. გაასუფთავეთ გაზის ხრახნის საწმენდი და რბილი ქსოვილით. გაწმენდის შემდეგ, ყოველთვის ჩაუტარეთ Throttle Body Relearn პროცედურა (ხელმისაწვდომია ამ აპლიკაციაში), რათა გადაეყაროს საბაზისო პოზიცია.</string>
    <string name="tip_8_title">გადაცემათა კოლოფის ზეთის სარქვლის მაგნიტის შემოწმება</string>
    <string name="tip_8_body">CVT-ის სითხის ჩამოსხმისას, ყოველთვის შეამოწმეთ ამოსახვეტი სარქველის მაგნიტი. თხელი ლითონის ფენა ნორმალურია (წვრილი ნაწილაკები). ლითონის ნამ­ტვ­რე­ვი ან ფხვნილი მიუთითებს შიდა ცვეთაზე — ნუ შეავსებთ სანამ წყაროს არ დიაგნოზირებთ. ეს შეიძლება CVT-ის შეცვლას გადაარჩინოს.</string>
    <string name="tip_9_title">ზეთის შეცვლა: გამოიყენეთ მხოლოდ 0W-20 სრული სინთეტიკა</string>
    <string name="tip_9_body">ყველა FB/FA სერიის ძრავს სჭირდება 0W-20 სრული სინთეტიკური ზეთი. უფრო მაღალი სიბლანტის ზეთის გამოყენება (5W-30, 5W-40) ზრდის ზეთის წნევას და შეიძლება ნაკადები დამაგროს. ასევე ამცირებს საწვავის ეფექტურობას. შეცვალეთ ყოველ 6,000–8,000 კმ-ზე Subaru FB სერიის ძრავებზე.</string>
    <string name="tip_10_title">სამუხრუჭე სითხე: შეცვლა ყოველ 2 წელიწადში</string>
    <string name="tip_10_body">სამუხრუჭე სითხე ჰიგ­როს­კო­პუ­ლია — დროთა განმავლობაში შთანთქავს ტენს, რაც ამცირებს დუღილის წერტილს. Subaru გირჩევთ DOT 3 ან DOT 4 სითხის შეცვლას ყოველ 2 წელიწადში, გარბენის მიუხედავად. გაუარესებული სითხე შეიძლება გამოიწვევდეს ორთქლის ჩაკეტვას და სამუხრუჭე სისტემის გაუარესებას მკვეთრი დამუხრუჭებისას.</string>
</resources>
