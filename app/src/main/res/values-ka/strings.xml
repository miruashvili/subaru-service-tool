    <!-- Maintenance tips -->
    <string name="tip_1">ზეთი შეცვალე ძრავში ყოველ 5000-დან 8000 კილომეტრამდე გარბენზე, იმის მიხედვით ქალაქში რამდენად ბევრს დადიხარ ან ტრასაზე. გამოიყენე მხოლოდ მაღალი ხარისხის ზეთი ცნობილი მწარმოებლებისგან. გამოიყენე მხოლოდ მაღალი ხარისხის ორ კლაპნიანი ზეთის ფილტრი.</string>
    <string name="tip_2">CVT ვარიატორ კოლოფში ზეთი შეცვალე ყოველ 50 000 კილომეტრზე. ჩაასხი აუცილებლად ის ზეთი, რომელსაც ზედ აწერია სუბარუს CVT დაშვება. აუცილებლად მოხსენი კოლოფის კარტერი და რკინის ფილტრიც შეცვალე ან თუ ვერ შოულობ გარეცხე. სრულ შეცვლას სჭირდება 10-12 ლიტრი კოლოფის ზეთი. მექანიკა კოლოფშიც ზეთი შეცვალე ყოველ 50 000 კილომეტრზე.</string>
    <string name="tip_3">წინა და უკანა ხიდში აუცილებლად შეცვალე ზეთი ყოველ 50 000 კილომეტრზე, ჩაასხი 75W90 დაშვების ნებისმიერი კარგი ბრენდის ზეთი.</string>
    <string name="tip_4">შეცვალე ქარხნული ანტიფრიზი 150 000 კილომეტრზე და მერე ცვალე ყოველ 100 000 კილომეტრში ერთხელ. აუცილებლად გამოიყენე სუბარუს დაშვები P-OAT ანტიფრიზი სილიკატების გარეშე. არ ჩაასხა უბრალო \'ლურჯი ან მწვანე\' ანტიფრიზი, არ ჩაასხა იაფიანი ანტიფრიზი, არ ჩაასხა უნივერსალი ანტიფრიზები. ერთ შეცვლაზე დაგჭირდება 8-10 ლიტრი მოცულობა.</string>
    <string name="tip_5">ყოველ 100 000 კილომეტრზე გამოცვალე ტორმუზის სითხე.</string>
    <string name="tip_6">ყოველ 100 000 კილომეტრზე გამოცვალე აალების სანთლები. დააყენე მხოლოდ ორიგინალები კატალოგის მიხედვით.</string>
    <string name="tip_7">ჰაერის ფილტრი შეცვალე ყოველ 15 000 - 20 000 კილომეტრზე, ისევე როგორც სალონის (კონდიციონერის) ფილტრი.</string>
    <string name="tip_8">ყოველ 20 000 კილომეტრზე საბურავები გადაანაცვლე, უკანები წინ, წინები კი უკან გადაიტანე. ასე თანაბარი ცვეთა ექნება.</string>
