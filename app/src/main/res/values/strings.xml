    <string name="proc_throttle_fail">Engine must be fully warm (≥80°C) and vehicle stationary.</string>
    <string name="proc_cvt_title">CVT Reset &amp; Learning</string>
    <string name="proc_cvt_desc">Resets CVT adaptive shift logic. Required after: CVT fluid change, valve body replacement, or solenoid replacement.</string>
